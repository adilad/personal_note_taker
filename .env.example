# === LiteLLM (cloud LLM) ===
LITELLM_API_KEY=your-api-key-here
LITELLM_BASE_URL=https://litellm.marqeta.com
LITELLM_MODEL_ID=openai/gpt-4o-mini
LITELLM_TEMPERATURE=0.3
MODEL_MAX_TOKENS=2000

# === LiteLLM Transcription (cloud Whisper) ===
USE_LITELLM_TRANSCRIPTION=0
LITELLM_TRANSCRIPTION_MODEL=whisper-1

# === Local LLM fallback (llama.cpp) ===
LLM_MODEL_PATH=~/models/llama-3-8b-instruct.Q4_K_M.gguf

# === Whisper ASR ===
WHISPER_MODEL=small       # tiny, base, small, medium, large-v2
WHISPER_BEAM_SIZE=5

# === VAD / Segmentation ===
VAD_AGGRESSIVENESS=1      # 0-3 (lower = more sensitive)
OFF_TIME_SEC=3
MAX_SEGMENT_SEC=120

# === Speaker diarization (optional) ===
USE_DIARIZATION=0
HF_TOKEN=

# === Noise reduction ===
USE_NOISEREDUCE=1

# === Flask UI ===
RECORDER_UI_HOST=127.0.0.1
RECORDER_UI_PORT=5000

# === API key auth ===
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
RECORDER_API_KEY=

# === Audio retention ===
AUDIO_RETENTION_DAYS=90
